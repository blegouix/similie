Problem {
  Name "Test scalar field problem";
  Physics ScalarFieldWithPowerCoupling;
  Solver MinimizeStrongFormulationResidual;
}

Solver {
  MaxIterations 250;
  RelativeTolerance 1e-6;
  JacobiMaxBlockSize 1;
  UseMatrixFree 1;
}

ScalarFieldWithPowerCoupling {
  Mass 2.5;
  CouplingConstant 3.25;
  CouplingPower 6.0;
}
